#!/usr/bin/env bash

# Prefer podman if available
RUNTIME=$(type podman &> /dev/null && echo podman || echo docker )

# Check if there is a runtime
if ! type $RUNTIME &> /dev/null; then
	echo Podman or Docker required for building in container
	exit 1
fi

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

pushd $SCRIPT_DIR/../../

$RUNTIME run --rm -v .:/prj fedora:43 bash -c "dnf install -y just; cd prj; just fetch-system-dep; . enter.sh; just prepare-system build"

popd
